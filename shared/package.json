{
  "name": "@jatbas/aic-core",
  "version": "0.10.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": "./dist/*"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -b && node -e \"require('node:fs').cpSync('src/storage/aic-ignore-entries.json','dist/storage/aic-ignore-entries.json')\"",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "22.19.15"
  },
  "dependencies": {
    "better-sqlite3": "12.8.0",
    "commander": "14.0.3",
    "diff": "8.0.3",
    "fast-glob": "3.3.3",
    "ignore": "7.0.4",
    "tiktoken": "1.0.21",
    "web-tree-sitter": "0.26.6",
    "tree-sitter-go": "0.25.0",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-java": "0.23.5",
    "typescript": "6.0.2",
    "zod": "4.3.6"
  }
}
