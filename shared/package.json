{
  "name": "@aic/shared",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    "./*": "./src/*"
  },
  "imports": {
    "#core/*": "./src/core/*",
    "#adapters/*": "./src/adapters/*",
    "#storage/*": "./src/storage/*",
    "#pipeline/*": "./src/pipeline/*"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "12.6.2",
    "commander": "13.1.0",
    "diff": "7.0.0",
    "fast-glob": "3.3.3",
    "ignore": "7.0.4",
    "tiktoken": "1.0.21",
    "web-tree-sitter": "0.26.6",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-rust": "0.24.0",
    "tree-sitter-python": "0.25.0",
    "tree-sitter-java": "0.23.5",
    "typescript": "5.7.2",
    "zod": "3.25.7"
  }
}
