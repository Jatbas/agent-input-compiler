{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/AIC-session-init.cjs"
      },
      {
        "command": "node .cursor/hooks/AIC-compile-context.cjs",
        "timeout": 20
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "node .cursor/hooks/AIC-before-submit-prewarm.cjs"
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/AIC-require-aic-compile.cjs"
      },
      {
        "command": "node .cursor/hooks/AIC-inject-conversation-id.cjs",
        "matcher": "MCP"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/AIC-block-no-verify.cjs",
        "matcher": "git"
      }
    ],
    "afterFileEdit": [],
    "sessionEnd": [
      {
        "command": "node .cursor/hooks/AIC-session-end.cjs"
      }
    ]
  }
}
