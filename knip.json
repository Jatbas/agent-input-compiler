{
  "ignore": [
    "scripts/**",
    ".cursor/**",
    "test/benchmarks/**",
    "integrations/cursor/hooks/**",
    "integrations/cursor/install.cjs",
    "integrations/cursor/uninstall.cjs",
    "integrations/claude/install.cjs",
    "integrations/claude/uninstall.cjs",
    "integrations/clean-global-aic-dir.cjs",
    "integrations/shared/strip-project-claude-md.cjs",
    "integrations/shared/uninstall-global-claude.cjs",
    "integrations/shared/uninstall-project-aic.cjs",
    "integrations/cursor/__tests__/AIC-require-aic-compile.test.cjs",
    "integrations/cursor/__tests__/AIC-inject-conversation-id.test.cjs",
    "integrations/claude/hooks/**",
    "integrations/claude/plugin/**",
    "integrations/claude/__tests__/**",
    "integrations/shared/read-stdin-sync.cjs"
  ],
  "workspaces": {
    ".": {},
    "shared": {
      "entry": ["src/storage/migrations/*.ts"],
      "ignoreDependencies": [
        "commander",
        "diff",
        "tree-sitter-go",
        "tree-sitter-python",
        "tree-sitter-rust",
        "tree-sitter-java"
      ]
    },
    "mcp": {}
  },
  "ignoreExportsUsedInFile": true,
  "ignoreIssues": {
    "mcp/src/server.ts": ["exports"],
    "shared/src/core/types/status-types.ts": ["types"],
    "shared/src/maintenance/cache-field-validators.ts": ["exports"]
  }
}
