{
  "name": "@jatbas/aic",
  "version": "0.10.2",
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "bin": "dist/server.js",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "integrations"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -b && node scripts/prepend-shebang.cjs && node scripts/bundle-standalone-uninstall.cjs && node scripts/bundle-cursor-installer.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jatbas/aic-core": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "3.25.7"
  }
}
