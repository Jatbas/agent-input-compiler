{
  "name": "@jatbas/aic",
  "version": "1.0.0",
  "description": "Agent Input Compiler — local-first MCP server for context compilation (Cursor, Claude Code, and other MCP clients)",
  "author": "Jorge Santos <jatbas@gmail.com> (https://github.com/Jatbas)",
  "license": "Apache-2.0",
  "funding": "https://github.com/sponsors/Jatbas",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jatbas/agent-input-compiler.git"
  },
  "homepage": "https://github.com/Jatbas/agent-input-compiler#readme",
  "bugs": {
    "url": "https://github.com/Jatbas/agent-input-compiler/issues"
  },
  "keywords": [
    "aic",
    "mcp",
    "model-context-protocol",
    "context-compiler",
    "ai",
    "llm",
    "cursor",
    "claude-code",
    "developer-tools",
    "prompt",
    "token-optimization",
    "codebase-context"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "type": "module",
  "main": "dist/server.js",
  "types": "dist/server.d.ts",
  "bin": "dist/server.js",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "integrations"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc -b && node scripts/prepend-shebang.cjs && node scripts/bundle-standalone-uninstall.cjs && node scripts/bundle-cursor-installer.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@jatbas/aic-core": "workspace:*",
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.9.0",
    "zod": "3.25.7"
  }
}
